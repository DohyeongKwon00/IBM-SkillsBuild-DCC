# AssemblyAI Speech to Text
# Get your API key at https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# IBM watsonx Orchestrate
ORCHESTRATE_URL=https://api.eu-gb.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>
ORCHESTRATE_API_KEY=

# Agent ID — ContextAgent is the listener and invokes PhraseAgent + SafetyAgent
# as collaborators, so only this one is called from the server.
# Fill in after running: orchestrate agents list
CONTEXT_AGENT_ID=
