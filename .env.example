# IBM watsonx Orchestrate
ORCHESTRATE_URL=https://api.eu-gb.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>
ORCHESTRATE_API_KEY=

# Agent IDs — fill in after running:
#   orchestrate agents list
SUPERVISOR_AGENT_ID=
CONTEXT_AGENT_ID=
PHRASE_AGENT_ID=
SAFETY_AGENT_ID=

# Pipeline routing
# true  = call SupervisorAgent (it chains Context->Phrase->Safety via collaborators)
# false = call 3 agents sequentially from FastAPI (fallback if collaborators don't work)
USE_SUPERVISOR=true
