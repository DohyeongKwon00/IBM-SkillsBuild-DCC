# IBM watsonx Orchestrate
ORCHESTRATE_URL=https://api.eu-gb.watson-orchestrate.cloud.ibm.com/instances/<your-instance-id>
ORCHESTRATE_API_KEY=

# Agent IDs — the server calls DiarizationAgent first to label each chunk
# as [student]/[other], then passes the labeled chunk to ContextAgent, which
# invokes PhraseAgent + SafetyAgent as collaborators.
# Fill in after running: orchestrate agents list
DIARIZATION_AGENT_ID=
CONTEXT_AGENT_ID=
